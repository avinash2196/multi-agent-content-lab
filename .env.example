# ============================================================
# multi-agent-content-lab — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# Never commit .env to source control.
#
# REQUIRED (minimum to run the pipeline):
OPENAI_API_KEY=your-openai-api-key
SERPAPI_API_KEY=your-serpapi-key

# OPTIONAL — secondary/fallback providers:
TAVILY_API_KEY=your-tavily-api-key
GEMINI_API_KEY=your-gemini-api-key

# OPTIONAL — Azure OpenAI (used as fallback when OpenAI is unavailable):
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# OPTIONAL — LangSmith tracing (see https://smith.langchain.com):
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=multi-agent-content-lab

# Backend settings:
BACKEND_API_KEY=            # Leave empty to disable auth in development
BACKEND_PORT=8000
BACKEND_RPM=60              # Max requests per minute to the /run endpoint
BACKEND_URL=http://localhost:8000

# Logging:
LOG_LEVEL=INFO
